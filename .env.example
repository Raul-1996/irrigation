# ── WB Irrigation — Environment Variables ──────────────────────────────────
# Copy this file to .env and adjust values as needed.
# All variables are optional — sensible defaults are used when unset.

# ── Flask / App ────────────────────────────────────────────────────────────
# SECRET_KEY for Flask sessions. Auto-generated to .secret_key if unset.
# SECRET_KEY=change-me-to-a-random-string

# Set to 1 for development / tests (disables CSRF, etc.)
# TESTING=0

# Secure session cookie (required when HTTPS terminates at a trusted proxy)
# SESSION_COOKIE_SECURE=1

# ── Server ─────────────────────────────────────────────────────────────────
# Safe default: loopback-only native listener.
# WB_HTTP_BIND_HOST=127.0.0.1
# PORT=8080

# Direct external HTTPS (certificate and key must be a readable, valid pair):
# WB_HTTP_BIND_HOST=0.0.0.0
# WB_HTTP_TLS_CERTFILE=/etc/wb-irrigation/server.crt
# WB_HTTP_TLS_KEYFILE=/etc/wb-irrigation/server.key
# Local readiness probes verify TLS by default. For a private CA:
# WB_HTTP_PROBE_CA_FILE=/etc/wb-irrigation/ca.crt
# Last-resort isolated-controller acknowledgement for a self-signed/mismatched cert:
# WB_HTTP_PROBE_INSECURE_TLS=1

# One trusted HTTPS reverse proxy, with Flask still bound to loopback:
# WB_HTTP_BIND_HOST=127.0.0.1
# WB_HTTP_TRUSTED_PROXY_HOPS=1
# SESSION_COOKIE_SECURE=1

# Isolated legacy LAN only: explicit acknowledgement of plaintext sessions.
# WB_HTTP_BIND_HOST=0.0.0.0
# WB_HTTP_ALLOW_INSECURE_EXTERNAL=1

# ── Timezone ───────────────────────────────────────────────────────────────
# IANA timezone for scheduler and logs (e.g. Asia/Yekaterinburg)
# TZ=UTC
# WB_TZ=UTC

# ── Encryption key for sensitive settings (base64-encoded) ─────────────────
# Auto-generated to .irrig_key if unset.
# IRRIG_SECRET_KEY=

# ── Scheduler ──────────────────────────────────────────────────────────────
# Log level for APScheduler (DEBUG, INFO, WARNING, ERROR)
# SCHEDULER_LOG_LEVEL=WARNING

# ── Basic Auth Proxy (basic_auth_proxy.py) ─────────────────────────────────
# UPSTREAM_PORT=8080
# AUTH_USER=admin
# AUTH_PASS=admin
# AUTH_REALM=Irrigation
# LISTEN_PORT=8081

# ── UI Agent Demo ──────────────────────────────────────────────────────────
# BASE_URL=http://127.0.0.1:8080
# CHROME_HEADLESS=0
# ADMIN_PASS=8888
