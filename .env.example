# ── WB Irrigation — Environment Variables ──────────────────────────────────
# Copy this file to .env and adjust values as needed.
# All variables are optional — sensible defaults are used when unset.

# ── Flask / App ────────────────────────────────────────────────────────────
# SECRET_KEY for Flask sessions. Auto-generated to .secret_key if unset.
# SECRET_KEY=change-me-to-a-random-string

# Set to 1 for development / tests (disables CSRF, etc.)
# TESTING=0

# Secure session cookie (set to 1 behind HTTPS proxy)
# SESSION_COOKIE_SECURE=0

# ── Server ─────────────────────────────────────────────────────────────────
# Port the app listens on inside the container
# PORT=8080

# ── Timezone ───────────────────────────────────────────────────────────────
# IANA timezone for scheduler and logs (e.g. Asia/Yekaterinburg)
# TZ=UTC
# WB_TZ=UTC

# ── Encryption key for sensitive settings (base64-encoded) ─────────────────
# Auto-generated to .irrig_key if unset.
# IRRIG_SECRET_KEY=

# ── Scheduler ──────────────────────────────────────────────────────────────
# Log level for APScheduler (DEBUG, INFO, WARNING, ERROR)
# SCHEDULER_LOG_LEVEL=WARNING

# ── Basic Auth Proxy (basic_auth_proxy.py) ─────────────────────────────────
# UPSTREAM_PORT=8080
# AUTH_USER=admin
# AUTH_PASS=admin
# AUTH_REALM=Irrigation
# LISTEN_PORT=8081

# ── UI Agent Demo ──────────────────────────────────────────────────────────
# BASE_URL=http://127.0.0.1:8080
# CHROME_HEADLESS=0
# ADMIN_PASS=8888
